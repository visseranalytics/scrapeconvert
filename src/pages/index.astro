---
import Base from '../layouts/Base.astro';
---
<Base>
  <main class="mx-auto max-w-4xl px-6 py-24 sm:py-32">
    <p class="mb-4 font-mono text-sm uppercase tracking-[0.04em] text-accent-400">
      Free and open source
    </p>
    <h1 class="mb-5 text-4xl font-semibold leading-[1.1] tracking-tight text-zinc-50 sm:text-5xl">
      Pull images off a site and convert them in one place
    </h1>
    <p class="mb-10 max-w-2xl text-lg leading-relaxed text-zinc-400">
      Point ScrapeConvert at a page, a list of URLs, or a whole sitemap. Review what it
      finds, then convert the images you want to WebP, AVIF, PNG, or JPEG. The conversion
      runs in your browser, so your files are never uploaded.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/app"
        class="inline-flex items-center rounded-lg bg-accent-400 px-6 py-3 font-semibold text-zinc-950 transition-colors duration-150 hover:bg-accent-300"
      >
        Open the app
      </a>
      <a
        href="https://github.com/scrapeconvert/scrapeconvert"
        class="inline-flex items-center rounded-lg border border-white/10 px-6 py-3 text-zinc-200 transition-colors duration-150 hover:border-white/25 hover:bg-white/5"
      >
        View the source
      </a>
    </div>
  </main>
</Base>
